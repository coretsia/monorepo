root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# Canonical: LF for everything by default (Git enforces too via .gitattributes).
end_of_line = lf

indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120

# Windows scripts MUST be CRLF (single exception).
[*.{bat,cmd}]
end_of_line = crlf

# PHP files follow PSR-12
[*.php]
indent_style = space
indent_size = 4
tab_width = 4

# PHPUnit *.phpt tests
[*.phpt]
indent_style = space
indent_size = 4

# JSON / YAML / NEON config files
# Вимикаємо обмеження довжини рядка для цих форматів
[*.{json,yml,yaml,neon}]
indent_style = space
indent_size = 2
max_line_length = off

# Markdown documentation
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# JS / TS / CSS / SCSS assets
[*.{js,ts,tsx,css,scss}]
indent_style = space
indent_size = 2

# Vue single-file components
[*.vue]
indent_style = space
indent_size = 2

# JSX / TSX (додатково, хоча .tsx вже покрито)
[*.{jsx,tsx}]
indent_style = space
indent_size = 2

# XML files
[*.xml]
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash,zsh}]
indent_style = tab
indent_size = 4
tab_width = 4

# Dockerfile(s)
[Dockerfile]
indent_style = space
indent_size = 4

# SQL files
[*.sql]
indent_style = space
indent_size = 2

# GraphQL
[*.{graphql,gql}]
indent_style = space
indent_size = 2

# Python (PEP 8)
[*.py]
indent_style = space
indent_size = 4

# Ruby
[*.rb]
indent_style = space
indent_size = 2

# Swift
[*.swift]
indent_style = space
indent_size = 4

# Kotlin
[*.kt]
indent_style = space
indent_size = 4

# Go (використовує табуляцію)
[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

# Git meta files
[.gitattributes]
indent_style = space
indent_size = 2

[.gitignore]
indent_style = space
indent_size = 2

# Makefile uses tabs
[{Makefile,*.mk}]
indent_style = tab
indent_size = 4

# Env files (values may be sensitive; formatting is minimal)
[.env*]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = true
insert_final_newline = true
