{
  "name": "coretsia/monorepo",
  "type": "project",
  "description": "Coretsia monorepo meta (framework + skeleton)",
  "keywords": [
    "framework",
    "psr",
    "ddd",
    "domain-driven-design",
    "modular",
    "enterprise",
    "performance",
    "microservices",
    "events",
    "cqrs",
    "observability"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Coretsia Team",
      "email": "team@coretsia.dev",
      "homepage": "https://coretsia.dev/"
    }
  ],
  "bin": [
    "coretsia"
  ],
  "require": {
    "php": "^8.4"
  },
  "repositories": [
    {
      "type": "path",
      "url": "framework",
      "options": {
        "symlink": true
      },
      "coretsia_managed": true
    },
    {
      "type": "path",
      "url": "framework/packages/*/*",
      "options": {
        "symlink": true
      },
      "coretsia_managed": true
    },
    {
      "type": "path",
      "url": "skeleton",
      "options": {
        "symlink": true
      },
      "coretsia_managed": true
    }
  ],
  "scripts": {
    "setup": [
      "@hooks:install",
      "@sync:repos",
      "@install:all",
      "@validate:all"
    ],
    "test": [
      "@framework:test"
    ],
    "test-fast": [
      "@framework:test-fast"
    ],
    "test-slow": [
      "@framework:test-slow"
    ],
    "ci": [
      "@sync:check",
      "@install:all",
      "@validate:all",
      "@gates",
      "@framework:test",
      "@lock:check"
    ],
    "arch:package-index:check": "@composer --no-interaction --working-dir=framework run-script arch:package-index:check --",
    "arch:package-index:generate": "@composer --no-interaction --working-dir=framework run-script arch:package-index:generate --",
    "spike:test": "@composer --no-interaction --working-dir=framework run-script spike:test --",
    "spike:test:determinism": "@composer --no-interaction --working-dir=framework run-script spike:test:determinism --",
    "spike:gate": "@composer --no-interaction --working-dir=framework run-script spike:gate --",
    "toolkit:gate": "@composer --no-interaction --working-dir=framework run-script toolkit:gate --",
    "tools:ia": "@composer --no-interaction --working-dir=framework run-script tools:ia --",
    "spike:io:policy": "@composer --no-interaction --working-dir=framework run-script spike:io:policy --",
    "spike:canonical:paths": "@composer --no-interaction --working-dir=framework run-script spike:canonical:paths --",
    "repo:text:gate": "@composer --no-interaction --working-dir=framework run-script repo:text:gate --",
    "spike:output:gate": "@composer --no-interaction --working-dir=framework run-script spike:output:gate --",
    "framework:test": "@composer --no-interaction --working-dir=framework run-script test --",
    "framework:test-fast": "@composer --no-interaction --working-dir=framework run-script test-fast --",
    "framework:test-slow": "@composer --no-interaction --working-dir=framework run-script test-slow --",
    "gates": "@composer --no-interaction --working-dir=framework run-script gates --",
    "no-skeleton-http-default:gate": "@composer --no-interaction --working-dir=framework run-script no-skeleton-http-default:gate --",
    "no-skeleton-bundles-default:gate": "@composer --no-interaction --working-dir=framework run-script no-skeleton-bundles-default:gate --",
    "no-skeleton-mode-presets-default:gate": "@composer --no-interaction --working-dir=framework run-script no-skeleton-mode-presets-default:gate --",
    "no-skeleton-modules-default:gate": "@composer --no-interaction --working-dir=framework run-script no-skeleton-modules-default:gate --",
    "contracts-only-ports:gate": "@composer --no-interaction --working-dir=framework run-script contracts-only-ports:gate --",
    "tag-constant-mirror:gate": "@composer --no-interaction --working-dir=framework run-script tag-constant-mirror:gate --",
    "package:phpunit:gate": "@composer --no-interaction --working-dir=framework run-script package:phpunit:gate --",
    "validate:root": "@composer --no-interaction validate --strict",
    "validate:framework": "@composer --no-interaction --working-dir=framework validate --strict",
    "validate:skeleton": "@composer --no-interaction --working-dir=skeleton validate --strict",
    "validate:all": [
      "@validate:root",
      "@validate:framework",
      "@validate:skeleton"
    ],
    "install:root": "@composer --no-interaction install --prefer-dist",
    "install:framework": "@composer --no-interaction --working-dir=framework install --prefer-dist",
    "install:skeleton": "@composer --no-interaction --working-dir=skeleton install --prefer-dist",
    "install:all": [
      "@install:root",
      "@install:framework",
      "@install:skeleton"
    ],
    "outdated:root": "@composer --no-interaction outdated",
    "outdated:framework": "@composer --no-interaction --working-dir=framework outdated",
    "outdated:skeleton": "@composer --no-interaction --working-dir=skeleton outdated",
    "outdated:all": [
      "@outdated:root",
      "@outdated:framework",
      "@outdated:skeleton"
    ],
    "dump-autoload:root": "@composer --no-interaction dump-autoload -o",
    "dump-autoload:framework": "@composer --no-interaction --working-dir=framework dump-autoload -o",
    "dump-autoload:skeleton": "@composer --no-interaction --working-dir=skeleton dump-autoload -o",
    "dump-autoload:all": [
      "@dump-autoload:root",
      "@dump-autoload:framework",
      "@dump-autoload:skeleton"
    ],
    "update:root": "@composer --no-interaction update",
    "update:framework": "@composer --no-interaction --working-dir=framework update",
    "update:skeleton": "@composer --no-interaction --working-dir=skeleton update",
    "update:all": [
      "@update:root",
      "@update:framework",
      "@update:skeleton"
    ],
    "sync:check": "@composer --no-interaction --working-dir=framework run-script sync:check --",
    "sync:repos": "@composer --no-interaction --working-dir=framework run-script sync:repos --",
    "hooks:install": "git config core.hooksPath .githooks",
    "lock:check": "git diff --exit-code -- composer.lock framework/composer.lock skeleton/composer.lock",
    "docs:structure": "@composer --no-interaction --working-dir=framework run-script docs:structure --",
    "docs:structure:tree": "@composer --no-interaction --working-dir=framework run-script docs:structure:tree --",
    "docs:structure:full": "@composer --no-interaction --working-dir=framework run-script docs:structure:full --",
    "package:new": "@composer --no-interaction --working-dir=framework run-script package:new --",
    "build:icons": "@composer --no-interaction --working-dir=framework run-script build:icons --"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.4.0"
    }
  }
}
