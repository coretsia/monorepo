{
  "name": "coretsia/core-dto-attribute",
  "type": "library",
  "description": "Canonical Coretsia DTO marker attribute for explicit transport-shape opt-in.",
  "keywords": [
    "coretsia",
    "php",
    "php84",
    "framework",
    "dto",
    "data-transfer-object",
    "attribute",
    "marker",
    "opt-in",
    "transport",
    "policy"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Coretsia Team",
      "email": "team@coretsia.dev",
      "homepage": "https://coretsia.dev/"
    }
  ],
  "require": {
    "php": "^8.4"
  },
  "autoload": {
    "psr-4": {
      "Coretsia\\Dto\\Attribute\\": "src/Attribute/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Coretsia\\Dto\\Attribute\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.4.0"
    }
  },
  "extra": {
    "coretsia": {
      "kind": "library"
    }
  }
}
