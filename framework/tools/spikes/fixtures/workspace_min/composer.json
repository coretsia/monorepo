{
  "name": "coretsia/monorepo",
  "type": "project",
  "description": "Workspace fixture (repo root)",
  "require": {
    "php": "^8.4"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.packagist.org"
    },
    {
      "type": "path",
      "url": "framework",
      "options": {
        "symlink": true
      },
      "coretsia_managed": true
    },
    {
      "type": "path",
      "url": "framework/packages/*/*",
      "options": {
        "symlink": true,
        "reference": "config",
        "versions": {
          "coretsia/core-contracts": "0.4.x-dev",
          "coretsia/core-kernel": "0.4.x-dev",
          "coretsia/devtools-internal-toolkit": "0.4.x-dev",
          "coretsia/platform-cli": "0.4.x-dev"
        }
      },
      "coretsia_managed": true
    },
    {
      "type": "path",
      "url": "skeleton",
      "options": {
        "symlink": true
      },
      "coretsia_managed": true
    }
  ],
  "config": {
    "sort-packages": true
  }
}
