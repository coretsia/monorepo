<phpunit
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.5/phpunit.xsd"
  bootstrap="_support/bootstrap.php"
  colors="true"
  failOnRisky="true"
  failOnWarning="true"
  beStrictAboutChangesToGlobalState="true"
  beStrictAboutOutputDuringTests="true"
  defaultTestSuite="spikes"
>
  <!--
    Spikes PHPUnit harness:

    - MUST be CWD-independent:
      bootstrap is config-file-relative: "_support/bootstrap.php"

    - MUST NOT write caches/artifacts into the git worktree:
      NO cacheDirectory / result-cache paths are declared here.
      Result cache is disabled via CLI flag "do-not-cache-result" (double-dash prefixed).

    - MUST NOT configure report outputs writing into the repo:
      No <logging/> and no coverage outputs are configured.
  -->

  <testsuites>
    <testsuite name="spikes">
      <!-- Scan the entire spikes sandbox for *Test.php -->
      <directory>.</directory>

      <!-- Exclude non-test areas -->
      <exclude>_support</exclude>
      <exclude>fixtures</exclude>
    </testsuite>
  </testsuites>

  <php>
    <!-- Keep output deterministic across OS -->
    <ini name="date.timezone" value="UTC"/>
  </php>
</phpunit>
